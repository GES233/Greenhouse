<html lang="zh-CN">
  <head>
    <meta charaset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>
      <%= @page_title %>
    </title>
    <%= @meta %>
  </head>
  <body>
    <%= @inner_content %>
    <%= if Mix.env() == :dev do %>
    <script>
      (function() {
        var es = new EventSource("/sse");
        es.addEventListener("reload", function(e) {
          window.location.reload();
        });
      })();
    </script>
    <% end %>
  </body>
</html>
